{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/style.css",
      "dest": "/style.css"
    },
    {
      "src": "/scriptv1.js",
      "dest": "/scriptv1.js"
    },
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ]
}